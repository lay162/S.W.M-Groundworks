# Copy to ".env" for local dev. For production, set the same names in GitHub → Settings → Secrets and variables → Actions.

# Public mailto fallback (embedded at build time; not secret).
VITE_BUSINESS_QUOTE_EMAIL="you@example.com"

# Google Sheets via Apps Script (browser POST — required for quote form on the built site).
# Same Web App URL you deploy from Google Apps Script → Manage deployments → copy /exec URL.
VITE_GOOGLE_APPS_SCRIPT_URL="https://script.google.com/macros/s/XXXX/exec"
# Must match var SECRET inside your Apps Script (see FOR-GOOGLE-APPS-SCRIPT-PASTE-ONLY.txt).
# Note: this value is embedded in the public JS bundle — use a long random string; not a password you reuse elsewhere.
VITE_GOOGLE_APPS_SCRIPT_SECRET="a-long-random-secret-matching-your-script"

# Optional: "true" to send photo base64 to Apps Script (Drive upload path in script). Large uploads may hit limits.
VITE_GOOGLE_APPS_SCRIPT_INCLUDE_PHOTOS="false"
