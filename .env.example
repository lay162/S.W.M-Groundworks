# Public quote address for the mailto fallback only (embedded at build time; not secret).
# Match your real inbox when you have it — same as OWNER_EMAIL is fine.
VITE_BUSINESS_QUOTE_EMAIL="you@example.com"

# Business inbox (Netlify server only — used by the enquiry function with SMTP)
OWNER_EMAIL="you@example.com"

# SMTP (free/cheap options: Gmail with an App Password, Zoho Mail, Outlook SMTP, etc.)
# Gmail: https://support.google.com/mail/answer/185833 — then often SMTP_HOST=smtp.gmail.com PORT=587 SECURE=false
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-user@example.com"
SMTP_PASS="smtp-password-or-app-password"
SMTP_FROM="S.W.M Groundsworks <no-reply@example.com>"

# Google Sheets (Apps Script webhook) — works without SMTP; set both on Netlify.
# See google-apps-script.txt for the script to paste in Google.
GOOGLE_APPS_SCRIPT_URL="https://script.google.com/macros/s/XXXX/exec"
GOOGLE_APPS_SCRIPT_SECRET="a-long-random-secret-matching-your-script"
# Set to true to send photo bytes to Apps Script (saves files into a Drive folder; see google-apps-script.txt).
GOOGLE_APPS_SCRIPT_INCLUDE_PHOTOS="false"

